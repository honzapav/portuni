{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities + sidecar spawn for the Node backend.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/portuni-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
