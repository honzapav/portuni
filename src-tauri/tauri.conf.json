{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portuni",
  "version": "0.1.0",
  "identifier": "ooo.workflow.portuni",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:4010",
    "beforeDevCommand": "npm --prefix app run dev",
    "beforeBuildCommand": "npm --prefix app run build && node scripts/build-sidecar.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Portuni",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/portuni-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
