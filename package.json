{
  "name": "portuni",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('node:fs'),path=require('node:path');const src='src/mcp/resources',dst='dist/mcp/resources';fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src))if(f.endsWith('.md'))fs.copyFileSync(path.join(src,f),path.join(dst,f));\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "lint": "biome check",
    "lint:strict": "biome check --error-on-warnings",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "opendal": "^0.49.2",
    "ulid": "^3.0.2",
    "varlock": "^0.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
